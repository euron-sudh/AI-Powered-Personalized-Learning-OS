# ══════════════════════════════════════════════════════════════════
#  LearnOS Backend — Production Environment Variables
#  Store ALL of these in AWS Secrets Manager under:
#    learnos/prod/backend/secrets  (JSON secret)
#  Reference them in ECS task definition via secretsManager ARN.
# ══════════════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
SUPABASE_JWT_SECRET=<supabase-jwt-secret>
SUPABASE_DB_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Redis ──────────────────────────────────────────────────────────
# In production use AWS ElastiCache (Redis) endpoint
REDIS_URL=redis://<elasticache-endpoint>:6379

# ── AI APIs ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...

# ── Server ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Production CORS — set to your Amplify / custom domain
CORS_ORIGINS=["https://app.learnos.io","https://www.learnos.io"]

# ── Sentry (optional) ──────────────────────────────────────────────
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# ── Sentiment tuning ──────────────────────────────────────────────
SENTIMENT_FRAME_INTERVAL_MS=5000
SENTIMENT_CONFIDENCE_THRESHOLD=0.6
